{
  "name": "mydashboard",
  "type": "module",
  "version": "1.0.0",
  "description": "Milk Management Dashboard - Track daily milk intake, suppliers, payments, and arrears",
  "scripts": {
    "dev": "wrangler pages dev ./dist --d1=milk-hissab-db --live-reload",
    "dev:build": "astro build && wrangler pages dev ./dist --d1=milk-hissab-db --live-reload",
    "dev:quick": "astro dev",
    "start": "npm run dev",
    "build": "astro build",
    "preview": "astro preview",
    "db:setup": "wrangler d1 execute milk-hissab-db --file=schema.sql",
    "db:setup:local": "wrangler d1 execute milk-hissab-db --file=schema.sql --local",
    "deploy": "astro build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "astro": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@vite-pwa/astro": "^1.2.0",
    "wrangler": "^3.0.0"
  }
}
