---
import Layout from '../components/Layout.astro';
import { getDB, getPasswords, recordToolUsage } from '../lib/db';

const user = Astro.locals.user;
const isLoggedIn = !!user;

let passwords = [];
const allCategories = new Set<string>();

if (isLoggedIn) {
  const db = getDB(Astro);
  await recordToolUsage(db, user.userId, 'passwords');
  passwords = await getPasswords(db, user.userId);
  
  // Extract all unique categories
  passwords.forEach((p: any) => {
    if (p.category) {
      allCategories.add(p.category.trim());
    }
  });
}

const passwordsSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Are my passwords visible to administrators?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Passwords are saved in the Cloudflare D1 SQL database using secure encryption mappings, isolated strictly to your account login."
      }
    },
    {
      "@type": "Question",
      "name": "Can I generate passwords without logging in?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To run the custom credentials vault, a free account is required. However, you can use our smart calculators and dashboards directly on the home page without logging in."
      }
    }
  ]
};
---
<Layout 
  title="Online Password Manager & Secure Vault | My Dashboard" 
  description="Generate high-entropy random passwords, securely store your login credentials, categorize service accounts, and copy them in a single tap."
  keywords="password manager, secure credentials vault, generate random password, online password vault, accounts manager, safe password generator"
  schema={passwordsSchema}
  accentColor="#4f46e5"
>
  {isLoggedIn ? (
    <main class="container animate-fade-in pb-4">
      <div class="flex-between mb-4 flex-wrap gap-4">
        <div>
          <h1 class="h2 mb-1">🔑 Passwords</h1>
          <p class="text-muted text-sm">Securely store and manage your login credentials.</p>
        </div>
        <button class="btn btn-primary" id="addPassBtn">+ Add Password</button>
      </div>

      <!-- Toolbar: Search & Filters -->
      <div class="glass-card mb-4 p-3">
        <div class="flex-between flex-wrap gap-3">
          <div class="flex gap-2 flex-1" style="min-width:200px;">
            <input type="text" id="passSearch" class="form-control" placeholder="Search by service, id, or email...">
          </div>
          <div class="flex gap-2 flex-wrap">
            <select id="categoryFilter" class="form-select" style="width:auto;">
              <option value="">All Categories</option>
              {[...allCategories].sort().map(cat => (
                <option value={cat}>{cat}</option>
              ))}
            </select>
          </div>
        </div>
      </div>

      <div class="passwords-grid" id="passwordsGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
        {passwords.length === 0 ? (
          <div class="glass-card p-8 text-center w-100" style="grid-column: 1 / -1;">
            <h5 class="text-muted">No passwords saved yet. Click "+ Add Password" to get started.</h5>
          </div>
        ) : (
          passwords.map((p: any) => (
            <div class="pass-card glass-card p-4 flex flex-col" 
                 data-id={p.id}
                 data-service={p.service_name.toLowerCase()}
                 data-login={p.service_id ? p.service_id.toLowerCase() : ''}
                 data-email={p.email ? p.email.toLowerCase() : ''}
                 data-cat={p.category ? p.category.toLowerCase() : ''}
                 style={`border-top: 4px solid ${p.color || '#4f46e5'};`}>
              <div class="flex-between mb-2">
                <span class="badge-sm" style="background:rgba(255,255,255,0.05); color:var(--text-muted); text-transform: uppercase;">
                  {p.category || 'General'}
                </span>
                <button class="btn btn-sm btn-icon edit-pass-btn" data-pass={JSON.stringify(p)} style="border:none; background:none; padding:0; height:auto; width:auto; font-size:0.9rem;" title="Edit details">✏️</button>
              </div>
              <h3 class="h5 mb-2 truncate">{p.service_name}</h3>
              
              <div class="space-y-2 text-xs mb-3">
                {p.service_id && (
                  <div class="flex-between">
                    <span class="text-muted">ID:</span>
                    <span class="fw-bold truncate flex gap-1 items-center" style="max-width:200px;">
                      {p.service_id}
                      <button class="copy-btn text-muted" data-copy={p.service_id} style="border:none; background:none; cursor:pointer;" title="Copy ID">📋</button>
                    </span>
                  </div>
                )}
                {p.email && (
                  <div class="flex-between">
                    <span class="text-muted">Email:</span>
                    <span class="fw-bold truncate flex gap-1 items-center" style="max-width:200px;">
                      {p.email}
                      <button class="copy-btn text-muted" data-copy={p.email} style="border:none; background:none; cursor:pointer;" title="Copy Email">📋</button>
                    </span>
                  </div>
                )}
                <div class="flex-between">
                  <span class="text-muted">Password:</span>
                  <span class="fw-bold flex gap-1 items-center">
                    <span class="password-masked font-mono">••••••••</span>
                    <span class="password-raw font-mono" style="display:none;">{p.password}</span>
                    <button class="toggle-raw text-muted" style="border:none; background:none; cursor:pointer;" title="Show Password">👁️</button>
                    <button class="copy-btn text-muted" data-copy={p.password} style="border:none; background:none; cursor:pointer;" title="Copy Password">📋</button>
                  </span>
                </div>
              </div>
              
              {p.website_url && (
                <a href={p.website_url.startsWith('http') ? p.website_url : `https://${p.website_url}`} target="_blank" class="btn btn-sm mt-auto" style="width:100%; justify-content:center; font-size:0.75rem; padding:0.3rem;">
                  🌐 Launch Website
                </a>
              )}
            </div>
          ))
        )}
      </div>

      <!-- Password Modal -->
      <div class="modal-overlay" id="passModal" style="display:none;">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="passModalTitle">Add Password</h5>
            <button class="modal-close" onclick="document.getElementById('passModal').style.display='none'">&times;</button>
          </div>
          <div class="modal-body">
            <form id="passForm">
              <input type="hidden" name="action" id="passAction" value="create">
              <input type="hidden" name="id" id="passId" value="">
              
              <div class="row mb-3">
                <div class="col-6">
                  <label class="form-label" for="passService">Service Name *</label>
                  <input type="text" id="passService" name="service_name" class="form-control" placeholder="e.g. Google, Netflix" required>
                </div>
                <div class="col-6">
                  <label class="form-label" for="passCategory">Category</label>
                  <input type="text" id="passCategory" name="category" class="form-control" placeholder="e.g. Social, Banking" list="categoryOptions">
                  <datalist id="categoryOptions">
                    <option value="Social"></option>
                    <option value="Work"></option>
                    <option value="Banking"></option>
                    <option value="Shopping"></option>
                    <option value="Entertainment"></option>
                  </datalist>
                </div>
              </div>

              <div class="row mb-3">
                <div class="col-6">
                  <label class="form-label" for="passLoginId">Login ID / Username</label>
                  <input type="text" id="passLoginId" name="service_id" class="form-control" placeholder="username">
                </div>
                <div class="col-6">
                  <label class="form-label" for="passLoginEmail">Login Email</label>
                  <input type="email" id="passLoginEmail" name="email" class="form-control" placeholder="email@example.com">
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label" for="passRaw">Password *</label>
                <div class="flex gap-2">
                  <input type="text" id="passRaw" name="password" class="form-control" placeholder="Enter secure password" required style="font-family: monospace;">
                  <button type="button" class="btn btn-secondary" id="btnGenModal" style="font-size:0.8rem; padding: 0.5rem 0.75rem;" title="Password Generator">⚡ Gen</button>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label" for="passUrl">Website URL</label>
                <input type="text" id="passUrl" name="website_url" class="form-control" placeholder="e.g. https://gmail.com">
              </div>

              <div class="row mb-4">
                <div class="col-12">
                  <label class="form-label">Color Accent</label>
                  <div class="color-picker-grid">
                    {['#ffffff', '#ff8a80', '#ffd180', '#ffff8d', '#ccff90', '#a7ffeb', '#80d8ff', '#cfd8dc'].map(c => (
                      <label class="color-option">
                        <input type="radio" name="color" value={c} checked={c === '#ffffff'}>
                        <span class="color-circle" style={`background:${c}`}></span>
                      </label>
                    ))}
                  </div>
                </div>
              </div>

              <div class="flex gap-2">
                <button type="submit" class="btn btn-primary" style="flex:1;">Save Password</button>
                <button type="button" class="btn btn-danger btn-sm" id="passDelBtn" style="display:none;">🗑️</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Password Generator Submodal -->
      <div class="modal-overlay" id="genModal" style="display:none; z-index: 1010; background: rgba(0,0,0,0.75);">
        <div class="modal-content modal-sm">
          <div class="modal-header">
            <h6 class="modal-title">⚡ Password Generator</h6>
            <button class="modal-close" id="closeGenBtn">&times;</button>
          </div>
          <div class="modal-body space-y-3 text-start">
            <div>
              <label class="form-label" for="genLen">Length: <span id="genLenVal" class="fw-bold text-accent">16</span></label>
              <input type="range" id="genLen" class="form-control" min="8" max="32" value="16" style="padding:0; cursor:pointer;">
            </div>
            
            <div class="space-y-2">
              <label class="toggle">
                <input type="checkbox" id="genUpper" checked>
                <span class="toggle-track"></span>
                <span class="text-xs text-secondary font-semibold">Uppercase (A-Z)</span>
              </label>
              <label class="toggle">
                <input type="checkbox" id="genLower" checked>
                <span class="toggle-track"></span>
                <span class="text-xs text-secondary font-semibold">Lowercase (a-z)</span>
              </label>
              <label class="toggle">
                <input type="checkbox" id="genNum" checked>
                <span class="toggle-track"></span>
                <span class="text-xs text-secondary font-semibold">Numbers (0-9)</span>
              </label>
              <label class="toggle">
                <input type="checkbox" id="genSym" checked>
                <span class="toggle-track"></span>
                <span class="text-xs text-secondary font-semibold">Symbols (!@#$%)</span>
              </label>
            </div>

            <div class="flex gap-2 pt-2">
              <button class="btn btn-secondary btn-sm" id="btnCancelGen" style="flex:1;">Cancel</button>
              <button class="btn btn-primary btn-sm" id="btnApplyGen" style="flex:1;">Apply</button>
            </div>
          </div>
        </div>
      </div>
    </main>
  ) : (
    <!-- Public SEO Landing Page -->
    <main class="container animate-fade-in pb-12">
      <div class="dashboard-hero py-12 mb-8 text-center glass-card p-8">
        <span class="badge mb-2">🔑 Secure Vault Utility</span>
        <h1 class="h1 mb-2" style="font-weight: 800; letter-spacing: -0.02em;">Online Password Manager &amp; Secure Vault</h1>
        <p class="text-muted text-sm max-w-sm mx-auto mb-6">
          Generate random passwords, securely store login credentials, filter portal accesses, and shield your account registries safely.
        </p>
        <div class="flex gap-3 justify-center">
          <a href="/login" class="btn btn-primary">Sign In to Dashboard</a>
          <a href="/register" class="btn">Create Free Account</a>
        </div>
      </div>

      <!-- Features grid -->
      <section class="glass-card p-6 mb-8">
        <h2 class="h4 mb-4 text-accent" style="font-weight: 800;">Key Features of our Secure Vault</h2>
        <div class="row gap-4" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); display: grid;">
          <div class="highlight-box">
            <h3 class="h6 fw-bold mb-2">⚡ Configurable Password Generator</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Generate high-entropy credentials dynamically. Pick length (up to 32 chars) and customize filters (letters, numbers, special characters).
            </p>
          </div>
          <div class="highlight-box">
            <h3 class="h6 fw-bold mb-2">🔐 Encryption-Ready Storage</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Save service accounts, login IDs, email credentials, and passwords safely inside your isolated workspace vault.
            </p>
          </div>
          <div class="highlight-box">
            <h3 class="h6 fw-bold mb-2">📋 One-Click Copy &amp; Masking</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Copy credentials directly to your clipboard in a tap. Mask or unmask passwords instantly with built-in toggle controls.
            </p>
          </div>
          <div class="highlight-box">
            <h3 class="h6 fw-bold mb-2">📂 Categorized Grouping</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Organize credentials under Banking, Social Media, Shopping, Work, or general directories. Custom-color tag each card.
            </p>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="glass-card p-6">
        <h2 class="h4 mb-4 text-accent" style="font-weight: 800;">Frequently Asked Questions (FAQs)</h2>
        <div class="space-y-6">
          <div>
            <h3 class="h6 fw-bold mb-1">Are my passwords visible to administrators?</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              No. Passwords are saved in the Cloudflare D1 SQL database using standard secure encryption mappings, isolated strictly to your account login.
            </p>
          </div>
          <div>
            <h3 class="h6 fw-bold mb-1">Can I generate passwords without logging in?</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              To run the custom credentials vault, a free account is required. However, you can use our smart calculators and dashboards directly on the home page without logging in.
            </p>
          </div>
        </div>
      </section>
    </main>
  )}
</Layout>

<script>
  const modal = document.getElementById('passModal');
  const form = document.getElementById('passForm') as HTMLFormElement;
  const addBtn = document.getElementById('addPassBtn');
  const searchInput = document.getElementById('passSearch') as HTMLInputElement;
  const categoryFilter = document.getElementById('categoryFilter') as HTMLSelectElement;

  function showModal() { modal!.style.display = 'flex'; }
  function hideModal() { modal!.style.display = 'none'; }

  addBtn?.addEventListener('click', () => {
    form.reset();
    document.getElementById('passModalTitle')!.textContent = 'Add Password';
    (document.getElementById('passAction') as HTMLInputElement).value = 'create';
    (document.getElementById('passId') as HTMLInputElement).value = '';
    document.getElementById('passDelBtn')!.style.display = 'none';
    showModal();
  });

  // Reveal functionality
  document.querySelectorAll('.toggle-raw').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const parent = btn.parentElement;
      const masked = parent?.querySelector('.password-masked') as HTMLElement;
      const raw = parent?.querySelector('.password-raw') as HTMLElement;
      if (raw.style.display === 'none') {
        raw.style.display = 'inline';
        masked.style.display = 'none';
        btn.textContent = '🙈';
        btn.setAttribute('title', 'Hide Password');
      } else {
        raw.style.display = 'none';
        masked.style.display = 'inline';
        btn.textContent = '👁️';
        btn.setAttribute('title', 'Show Password');
      }
    });
  });

  // Copy functionality
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const text = btn.getAttribute('data-copy');
      if (text) {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = '✅';
        setTimeout(() => btn.textContent = original, 1500);
      }
    });
  });

  // Edit functionality
  document.querySelectorAll('.edit-pass-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const passDataStr = btn.getAttribute('data-pass');
      if (!passDataStr) return;
      const p = JSON.parse(passDataStr);

      document.getElementById('passModalTitle')!.textContent = 'Edit Password';
      (document.getElementById('passAction') as HTMLInputElement).value = 'update';
      (document.getElementById('passId') as HTMLInputElement).value = p.id;
      (document.getElementById('passService') as HTMLInputElement).value = p.service_name;
      (document.getElementById('passCategory') as HTMLInputElement).value = p.category || '';
      (document.getElementById('passLoginId') as HTMLInputElement).value = p.service_id || '';
      (document.getElementById('passLoginEmail') as HTMLInputElement).value = p.email || '';
      (document.getElementById('passRaw') as HTMLInputElement).value = p.password;
      (document.getElementById('passUrl') as HTMLInputElement).value = p.website_url || '';
      
      const radio = form.querySelector(`input[name="color"][value="${p.color || '#ffffff'}"]`) as HTMLInputElement;
      if (radio) radio.checked = true;

      document.getElementById('passDelBtn')!.style.display = 'block';
      showModal();
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    const res = await fetch('/api/passwords', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    
    if (res.ok) window.location.reload();
  });

  document.getElementById('passDelBtn')?.addEventListener('click', async () => {
    if (!confirm('Delete this password entry?')) return;
    const id = (document.getElementById('passId') as HTMLInputElement).value;
    const res = await fetch('/api/passwords', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'delete', id })
    });
    if (res.ok) window.location.reload();
  });

  // Password Generator Submodal functionality
  const btnGenModal = document.getElementById('btnGenModal');
  const genModal = document.getElementById('genModal');
  const closeGenBtn = document.getElementById('closeGenBtn');
  const btnCancelGen = document.getElementById('btnCancelGen');
  const btnApplyGen = document.getElementById('btnApplyGen');
  const genLen = document.getElementById('genLen') as HTMLInputElement;
  const genLenVal = document.getElementById('genLenVal');
  
  btnGenModal?.addEventListener('click', () => {
    if (genModal) genModal.style.display = 'flex';
  });
  
  const closeGenerator = () => {
    if (genModal) genModal.style.display = 'none';
  };
  
  closeGenBtn?.addEventListener('click', closeGenerator);
  btnCancelGen?.addEventListener('click', closeGenerator);
  genModal?.addEventListener('click', (e) => {
    if (e.target === genModal) closeGenerator();
  });

  genLen?.addEventListener('input', () => {
    if (genLenVal) genLenVal.textContent = genLen.value;
  });

  btnApplyGen?.addEventListener('click', () => {
    const len = parseInt(genLen.value) || 16;
    const useUpper = (document.getElementById('genUpper') as HTMLInputElement).checked;
    const useLower = (document.getElementById('genLower') as HTMLInputElement).checked;
    const useNum = (document.getElementById('genNum') as HTMLInputElement).checked;
    const useSym = (document.getElementById('genSym') as HTMLInputElement).checked;
    
    let charset = "";
    if (useUpper) charset += "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    if (useLower) charset += "abcdefghijklmnopqrstuvwxyz";
    if (useNum) charset += "0123456789";
    if (useSym) charset += "!@#$%^&*()_+-=[]{}|;:,.<>?";
    
    if (charset === "") {
      charset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
    }
    
    let newPassword = "";
    const array = new Uint32Array(len);
    window.crypto.getRandomValues(array);
    for (let i = 0; i < len; i++) {
      newPassword += charset.charAt(array[i] % charset.length);
    }
    
    const passRawInput = document.getElementById('passRaw') as HTMLInputElement;
    if (passRawInput) {
      passRawInput.value = newPassword;
    }
    closeGenerator();
  });

  function filterPass() {
    if (!searchInput || !categoryFilter) return;
    const query = searchInput.value.toLowerCase();
    const cat = categoryFilter.value.toLowerCase();
    
    document.querySelectorAll('.pass-card').forEach(card => {
      const c = card as HTMLElement;
      const service = c.dataset.service || '';
      const login = c.dataset.login || '';
      const email = c.dataset.email || '';
      const category = c.dataset.cat || '';
      
      const matchesSearch = service.includes(query) || login.includes(query) || email.includes(query);
      const matchesCat = cat === '' || category === cat;
      
      c.style.display = (matchesSearch && matchesCat) ? 'flex' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterPass);
  categoryFilter?.addEventListener('change', filterPass);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) hideModal();
  });
</script>

<style>
  .pass-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .pass-card {
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    min-height: 250px;
  }
  .pass-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -10px rgba(0,0,0,0.3);
  }
  .credential-item {
    background: rgba(255,255,255,0.03);
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .pass-reveal-input {
    background: transparent;
    border: none;
    color: var(--text-primary);
    width: 100%;
    outline: none;
  }
  .reveal-btn, .copy-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    padding: 2px 4px;
    border-radius: 4px;
    transition: background 0.2s;
  }
  .reveal-btn:hover, .copy-btn:hover {
    background: rgba(255,255,255,0.1);
  }
  .color-picker-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0.5rem;
  }
  .color-option {
    cursor: pointer;
    position: relative;
  }
  .color-option input {
    position: absolute;
    opacity: 0;
  }
  .color-circle {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 2px solid transparent;
    transition: all 0.2s;
  }
  .color-option input:checked + .color-circle {
    border-color: var(--accent-primary);
    transform: scale(1.1);
  }
  .d-block { display: block; }
</style>
