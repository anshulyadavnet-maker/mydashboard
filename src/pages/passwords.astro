---
import Layout from '../components/Layout.astro';
import { getDB, getPasswords } from '../lib/db';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/login');

const db = getDB(Astro);
const passwords = await getPasswords(db, user.userId);

// Extract all unique categories
const allCategories = new Set<string>();
passwords.forEach((p: any) => {
  if (p.category) {
    allCategories.add(p.category.trim());
  }
});
---
<Layout title="Passwords - Milk Hissab">
  <div class="container animate-fade-in pb-4">
    <div class="flex-between mb-4 flex-wrap gap-4">
      <div>
        <h1 class="h2 mb-1">🔑 Passwords</h1>
        <p class="text-muted text-sm">Securely store and manage your login credentials.</p>
      </div>
      <button class="btn btn-primary" id="addPassBtn">+ Add Password</button>
    </div>

    <!-- Toolbar: Search & Filters -->
    <div class="glass-card mb-4 p-3">
      <div class="flex-between flex-wrap gap-3">
        <div class="flex gap-2 flex-1" style="min-width:200px;">
          <input type="text" id="passSearch" class="form-control" placeholder="Search by service, id, or email...">
        </div>
        <div class="flex gap-2 flex-wrap">
          <select id="categoryFilter" class="form-select" style="width:auto;">
            <option value="">All Categories</option>
            {[...allCategories].sort().map(cat => (
              <option value={cat}>{cat}</option>
            ))}
          </select>
          <select id="colorFilter" class="form-select" style="width:auto;">
            <option value="">All Colors</option>
            <option value="#ffffff">White</option>
            <option value="#ff8a80">Red</option>
            <option value="#ffd180">Orange</option>
            <option value="#ffff8d">Yellow</option>
            <option value="#ccff90">Green</option>
            <option value="#a7ffeb">Teal</option>
            <option value="#80d8ff">Blue</option>
            <option value="#cfd8dc">Grey</option>
          </select>
        </div>
      </div>
    </div>

    <div class="pass-grid" id="passGrid">
      {passwords.length === 0 ? (
        <div class="glass-card p-8 text-center w-100" style="grid-column: 1 / -1;">
          <div style="font-size:3rem; margin-bottom:1rem;">🔐</div>
          <h5 class="text-muted">No passwords saved yet.</h5>
        </div>
      ) : (
        passwords.map((p: any) => (
          <div class="pass-card glass-card p-4" 
               data-id={p.id} 
               data-service={p.service_name.toLowerCase()} 
               data-sid={p.service_id ? p.service_id.toLowerCase() : ''}
               data-email={p.email ? p.email.toLowerCase() : ''}
               data-category={p.category.toLowerCase()}
               data-color={p.color}
               style={`border-top: 4px solid ${p.color};`}>
            
            <div class="flex-between mb-3">
              <h3 class="h5 mb-0">{p.service_name}</h3>
              <span class="badge-sm" style="background:rgba(255,255,255,0.05); color:var(--text-muted);">
                {p.category}
              </span>
            </div>

            <div class="credentials-box space-y-2 mb-4">
              {p.service_id && (
                <div class="credential-item">
                  <span class="text-xs text-muted d-block">User ID</span>
                  <div class="flex-between gap-2">
                    <span class="text-sm truncate">{p.service_id}</span>
                    <button class="copy-btn" data-copy={p.service_id} title="Copy ID">📋</button>
                  </div>
                </div>
              )}
              {p.email && (
                <div class="credential-item">
                  <span class="text-xs text-muted d-block">Email</span>
                  <div class="flex-between gap-2">
                    <span class="text-sm truncate">{p.email}</span>
                    <button class="copy-btn" data-copy={p.email} title="Copy Email">📋</button>
                  </div>
                </div>
              )}
              <div class="credential-item">
                <span class="text-xs text-muted d-block">Password</span>
                <div class="flex-between gap-2">
                  <input type="password" class="pass-reveal-input text-sm" value={p.password} readonly>
                  <div class="flex gap-1">
                    <button class="reveal-btn" title="Show/Hide">👁️</button>
                    <button class="copy-btn" data-copy={p.password} title="Copy Password">📋</button>
                  </div>
                </div>
              </div>
            </div>

            <div class="flex-between mt-auto pt-2 border-t border-white/5">
              <div class="text-xs text-muted">
                Updated: {new Date(p.updated_at).toLocaleDateString()}
              </div>
              <button class="btn btn-sm btn-ghost edit-btn">Edit</button>
            </div>
          </div>
        ))
      )}
    </div>
  </div>

  <!-- Password Modal -->
  <div class="modal-overlay" id="passModal" style="display:none;">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="passModalTitle">Add Password</h5>
        <button class="modal-close" onclick="document.getElementById('passModal').style.display='none'">&times;</button>
      </div>
      <div class="modal-body">
        <form id="passForm">
          <input type="hidden" name="action" id="passAction" value="create">
          <input type="hidden" name="id" id="passId" value="">
          
          <div class="row mb-3">
            <div class="col-6">
              <label class="form-label">Website/App *</label>
              <input type="text" class="form-control" name="service_name" id="passService" required placeholder="e.g. Google">
            </div>
            <div class="col-6">
              <label class="form-label">Category *</label>
              <input type="text" class="form-control" name="category" id="passCategory" required list="categoryList" placeholder="e.g. Social">
              <datalist id="categoryList">
                {[...allCategories].map(cat => <option value={cat} />)}
              </datalist>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-6">
              <label class="form-label">User ID</label>
              <input type="text" class="form-control" name="service_id" id="passSID" placeholder="Username">
            </div>
            <div class="col-6">
              <label class="form-label">Email</label>
              <input type="email" class="form-control" name="email" id="passEmail" placeholder="you@example.com">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Password *</label>
            <div class="flex gap-2">
              <input type="text" class="form-control" name="password" id="passValue" required placeholder="Enter password">
              <button type="button" class="btn btn-secondary" id="genPassBtn" title="Generate Password">🎲</button>
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label">Color Theme</label>
            <div class="color-picker-grid">
              {['#ffffff', '#ff8a80', '#ffd180', '#ffff8d', '#ccff90', '#a7ffeb', '#80d8ff', '#cfd8dc'].map(c => (
                <label class="color-option">
                  <input type="radio" name="color" value={c} checked={c === '#ffffff'}>
                  <span class="color-circle" style={`background:${c}`}></span>
                </label>
              ))}
            </div>
          </div>

          <div class="flex gap-2">
            <button type="submit" class="btn btn-primary" style="flex:1;">Save Password</button>
            <button type="button" class="btn btn-danger btn-sm" id="passDelBtn" style="display:none;">🗑️</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById('passModal');
  const form = document.getElementById('passForm') as HTMLFormElement;
  const addBtn = document.getElementById('addPassBtn');
  const searchInput = document.getElementById('passSearch') as HTMLInputElement;
  const categoryFilter = document.getElementById('categoryFilter') as HTMLSelectElement;
  const colorFilter = document.getElementById('colorFilter') as HTMLSelectElement;

  function showModal() { modal!.style.display = 'flex'; }
  function hideModal() { modal!.style.display = 'none'; }

  addBtn?.addEventListener('click', () => {
    form.reset();
    document.getElementById('passModalTitle')!.textContent = 'Add Password';
    (document.getElementById('passAction') as HTMLInputElement).value = 'create';
    (document.getElementById('passId') as HTMLInputElement).value = '';
    document.getElementById('passDelBtn')!.style.display = 'none';
    showModal();
  });

  // Reveal functionality
  document.querySelectorAll('.reveal-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const container = btn.closest('.credential-item');
      const input = container?.querySelector('input') as HTMLInputElement;
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
      } else {
        input.type = 'password';
        btn.textContent = '👁️';
      }
    });
  });

  // Copy functionality
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const text = btn.getAttribute('data-copy');
      if (text) {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = '✅';
        setTimeout(() => btn.textContent = original, 1500);
      }
    });
  });

  // Edit functionality
  document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const card = btn.closest('.pass-card') as HTMLElement;
      const id = card.getAttribute('data-id');
      const service = card.querySelector('h3')?.textContent;
      const category = card.querySelector('.badge-sm')?.textContent?.trim();
      const sid = card.dataset.sid;
      const email = card.dataset.email;
      const password = (card.querySelector('.pass-reveal-input') as HTMLInputElement).value;
      const color = card.getAttribute('data-color');

      document.getElementById('passModalTitle')!.textContent = 'Edit Password';
      (document.getElementById('passAction') as HTMLInputElement).value = 'update';
      (document.getElementById('passId') as HTMLInputElement).value = id!;
      (document.getElementById('passService') as HTMLInputElement).value = service!;
      (document.getElementById('passCategory') as HTMLInputElement).value = category!;
      (document.getElementById('passSID') as HTMLInputElement).value = sid || '';
      (document.getElementById('passEmail') as HTMLInputElement).value = email || '';
      (document.getElementById('passValue') as HTMLInputElement).value = password;
      
      const radio = form.querySelector(`input[name="color"][value="${color}"]`) as HTMLInputElement;
      if (radio) radio.checked = true;

      document.getElementById('passDelBtn')!.style.display = 'block';
      showModal();
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    const res = await fetch('/api/passwords', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    
    if (res.ok) window.location.reload();
  });

  document.getElementById('passDelBtn')?.addEventListener('click', async () => {
    if (!confirm('Delete this password entry?')) return;
    const id = (document.getElementById('passId') as HTMLInputElement).value;
    const res = await fetch('/api/passwords', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'delete', id })
    });
    if (res.ok) window.location.reload();
  });

  document.getElementById('genPassBtn')?.addEventListener('click', () => {
    const charset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+";
    let retVal = "";
    for (let i = 0, n = charset.length; i < 12; ++i) {
      retVal += charset.charAt(Math.floor(Math.random() * n));
    }
    (document.getElementById('passValue') as HTMLInputElement).value = retVal;
  });

  function filterPass() {
    const query = searchInput.value.toLowerCase();
    const cat = categoryFilter.value.toLowerCase();
    const color = colorFilter.value;
    
    document.querySelectorAll('.pass-card').forEach(card => {
      const c = card as HTMLElement;
      const service = c.dataset.service || '';
      const sid = c.dataset.sid || '';
      const email = c.dataset.email || '';
      const category = c.dataset.category || '';
      const cardColor = c.dataset.color || '';
      
      const matchesSearch = service.includes(query) || sid.includes(query) || email.includes(query);
      const matchesCat = cat === '' || category === cat;
      const matchesColor = color === '' || cardColor === color;
      
      c.style.display = (matchesSearch && matchesCat && matchesColor) ? 'flex' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterPass);
  categoryFilter?.addEventListener('change', filterPass);
  colorFilter?.addEventListener('change', filterPass);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) hideModal();
  });
</script>

<style>
  .pass-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .pass-card {
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    min-height: 250px;
  }
  .pass-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -10px rgba(0,0,0,0.3);
  }
  .credential-item {
    background: rgba(255,255,255,0.03);
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .pass-reveal-input {
    background: transparent;
    border: none;
    color: var(--text-primary);
    width: 100%;
    outline: none;
  }
  .reveal-btn, .copy-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    padding: 2px 4px;
    border-radius: 4px;
    transition: background 0.2s;
  }
  .reveal-btn:hover, .copy-btn:hover {
    background: rgba(255,255,255,0.1);
  }
  .color-picker-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0.5rem;
  }
  .color-option {
    cursor: pointer;
    position: relative;
  }
  .color-option input {
    position: absolute;
    opacity: 0;
  }
  .color-circle {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 2px solid transparent;
    transition: all 0.2s;
  }
  .color-option input:checked + .color-circle {
    border-color: var(--accent-primary);
    transform: scale(1.1);
  }
  .d-block { display: block; }
</style>
