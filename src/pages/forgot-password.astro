---
import Layout from '../components/Layout.astro';
---
<Layout 
  title="Forgot Password - MYDASHBOARD.CO.IN"
  description="Request a password reset link to recover access to your private utility workspace."
  keywords="forgot password, reset password, recover credentials"
>
  <main class="login-page">
    <div class="glass-card login-card">
      <h1><img src="/favicon.svg" alt="Logo" class="login-icon" style="width: 38px; height: 38px; vertical-align: middle; margin-right: 8px; display: inline-block; object-fit: contain;" /> MYDASHBOARD.CO.IN</h1>
      <p class="text-muted text-sm mb-4">Reset Your Password</p>
      
      <form id="forgotForm" class="text-start">
        <div class="mb-3">
          <label class="form-label" for="email">Email Address</label>
          <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required autofocus>
        </div>
        
        <button type="submit" class="btn btn-primary w-100" id="sendBtn">Send Reset Code</button>
        <div id="alertBox" class="alert alert-danger mt-3" style="display:none;"></div>
        <div id="successBox" class="alert alert-success mt-3" style="display:none;"></div>
        
        <div id="devBox" class="glass-card mt-3 text-start" style="display:none; padding: 1rem; border-color: rgba(20, 184, 166, 0.3); background: rgba(20, 184, 166, 0.05);">
          <h5 style="color: var(--accent-primary); margin-top: 0; margin-bottom: 0.5rem; font-size: 0.95rem;">🛠️ Local Developer Mode Notice</h5>
          <p class="text-sm text-muted mb-3" style="line-height: 1.4;">
            SMTP mailing is offline in local dev. Your generated password reset code is: 
            <strong id="devCodeVal" style="color: var(--text-primary); font-family: monospace; font-size: 1.1rem; background: rgba(255,255,255,0.1); padding: 0.1rem 0.3rem; border-radius: 4px;"></strong>
          </p>
          <a id="devResetLink" href="#" class="btn btn-primary btn-sm w-100" style="text-align: center;">Reset Password Now &rarr;</a>
        </div>
      </form>
      
      <p class="text-muted text-sm mt-3">
        Remembered your password?
        <a href="/login" style="color: var(--accent-primary); text-decoration: none; font-weight: 600;">Sign in</a>
      </p>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('forgotForm') as HTMLFormElement;
  const alertBox = document.getElementById('alertBox') as HTMLDivElement;
  const successBox = document.getElementById('successBox') as HTMLDivElement;
  const devBox = document.getElementById('devBox') as HTMLDivElement;
  const devCodeVal = document.getElementById('devCodeVal') as HTMLElement;
  const devResetLink = document.getElementById('devResetLink') as HTMLAnchorElement;
  const btn = document.getElementById('sendBtn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    alertBox.style.display = 'none';
    successBox.style.display = 'none';
    devBox.style.display = 'none';
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Processing...';

    const emailInput = document.getElementById('email') as HTMLInputElement;
    const email = emailInput.value;

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      
      const data = await res.json();
      
      if (data.success) {
        if (data.emailSent) {
            successBox.innerHTML = `A password reset code has been sent to <strong>${email}</strong>.<br><br><span class="spinner" style="width: 14px; height: 14px; margin-right: 6px;"></span> Redirecting to code verification...`;
            successBox.style.display = 'block';
            devBox.style.display = 'none';
            btn.disabled = true;
            
            setTimeout(() => {
              window.location.href = `/reset-password?email=${encodeURIComponent(email)}`;
            }, 2500);
          } else {
            successBox.textContent = data.message || 'Reset code generated.';
            successBox.style.display = 'block';
            
            if (data.devCode) {
              devCodeVal.textContent = data.devCode;
              devResetLink.href = `/reset-password?email=${encodeURIComponent(email)}&code=${encodeURIComponent(data.devCode)}`;
              
              const devNoticeTitle = document.querySelector('#devBox h5') as HTMLElement;
              const devNoticeDesc = document.querySelector('#devBox p') as HTMLElement;
              if (devNoticeTitle) devNoticeTitle.textContent = '🛠️ Local Developer Mode Notice';
              if (devNoticeDesc) {
                const errorDetail = data.emailError ? ` (Reason: ${data.emailError})` : '';
                devNoticeDesc.innerHTML = `Email dispatch skipped/failed${errorDetail}. For local development, copy your reset code: <strong id="devCodeVal" style="color: var(--text-primary); font-family: monospace; font-size: 1.1rem; background: rgba(255,255,255,0.1); padding: 0.1rem 0.3rem; border-radius: 4px;">${data.devCode}</strong>`;
              }
              devBox.style.display = 'block';
            }
          }
      } else {
        alertBox.textContent = data.message || 'Request failed. Please try again.';
        alertBox.style.display = 'block';
      }
    } catch {
      alertBox.textContent = 'Network error. Please try again.';
      alertBox.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Send Reset Code';
    }
  });
</script>
