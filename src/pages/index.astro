---
import Layout from '../components/Layout.astro';
import { getDB, getToolUsage } from '../lib/db';

const user = Astro.locals.user;
let loggedIn = false;
let userName = '';

interface Tool {
  id: string;
  name: string;
  desc: string;
  href: string;
  icon: string;
  color: string;
  requiresLogin: boolean;
  isUpcoming: boolean;
  defaultOrder: number;
  features?: string[];
}

const TOOLS: Tool[] = [
  {
    id: 'milk',
    name: 'Milk Ledger',
    desc: 'Log daily milk delivery (Doodh ka Hissab), rate, suppliers, monthly payments, and balances.',
    href: '/milk',
    icon: '🥛',
    color: '#0284c7',
    requiresLogin: true,
    isUpcoming: false,
    defaultOrder: 1
  },
  {
    id: 'expenses',
    name: 'Expense Manager',
    desc: 'Categorize spendings, track monthly budget limits, and see total stats of your expenses.',
    href: '/expenses',
    icon: '💸',
    color: '#e11d48',
    requiresLogin: true,
    isUpcoming: false,
    defaultOrder: 2
  },
  {
    id: 'notes',
    name: 'Quick Notes',
    desc: 'Capture thoughts, reminders, todo lists, and organize using tags and custom colors.',
    href: '/notes',
    icon: '📝',
    color: '#d97706',
    requiresLogin: true,
    isUpcoming: false,
    defaultOrder: 3
  },
  {
    id: 'passwords',
    name: 'Password Manager',
    desc: 'Securely store logins, emails, website details, and generate secure passwords.',
    href: '/passwords',
    icon: '🔑',
    color: '#4f46e5',
    requiresLogin: true,
    isUpcoming: false,
    defaultOrder: 4
  },
  {
    id: 'calculator',
    name: 'Smart Calculator',
    desc: 'Calculate basic arithmetic instantly. Includes calculation history and full keyboard support.',
    href: '/calculator',
    icon: '📊',
    color: '#64748b',
    requiresLogin: false,
    isUpcoming: false,
    defaultOrder: 5
  },
  {
    id: 'age-calculator',
    name: 'Age Calculator',
    desc: 'Find your exact age in years/months/days, next birthday countdown, and zodiac sign.',
    href: '/age-calculator',
    icon: '🎂',
    color: '#10b981',
    requiresLogin: false,
    isUpcoming: false,
    defaultOrder: 6
  },
  {
    id: 'cylinder',
    name: 'Cylinder Tracker',
    desc: 'Track gas cylinder refill intervals, usage duration, and calculate next booking due date.',
    href: '#cylinder',
    icon: '🔥',
    color: '#ea580c',
    requiresLogin: true,
    isUpcoming: true,
    defaultOrder: 7,
    features: [
      'Track gas cylinder delivery dates & prices',
      'Estimate monthly/daily usage rate based on past logs',
      'Receive push notifications before the estimated empty date',
      'Calculate next booking date reminder'
    ]
  },
  {
    id: 'newspaper',
    name: 'Newspaper Ledger',
    desc: 'Track daily newspaper deliveries, calculate monthly dues, and handle vacation breaks.',
    href: '#newspaper',
    icon: '📰',
    color: '#0891b2',
    requiresLogin: true,
    isUpcoming: true,
    defaultOrder: 8,
    features: [
      'Log daily newspaper delivery status & monthly subscription rates',
      'Mark suspension dates (vacations/holidays) to halt logging',
      'Automated monthly bill adjustments for skipped days',
      'Support for multiple regional and international newspaper agencies'
    ]
  },
  {
    id: 'tuition',
    name: 'Tuition Fee Tracker',
    desc: 'Manage multiple classes, student details, monthly fee dues, and track payment receipts.',
    href: '#tuition',
    icon: '🎓',
    color: '#8b5cf6',
    requiresLogin: true,
    isUpcoming: true,
    defaultOrder: 9,
    features: [
      'Manage list of student accounts, classes, and subjects',
      'Configure billing models (per class, monthly flat rate, hourly)',
      'Automated invoice generation & WhatsApp/Email friendly payment links',
      'Log cash/digital receipt history'
    ]
  },
  {
    id: 'rent',
    name: 'Rent Ledger',
    desc: 'Maintain rent logs, track tenant/landlord agreements, and set due date reminders.',
    href: '#rent',
    icon: '🏠',
    color: '#db2777',
    requiresLogin: true,
    isUpcoming: true,
    defaultOrder: 10,
    features: [
      'Keep records of tenant profiles, monthly rent, and security deposit',
      'Log repair costs, utilities billing, and deductions',
      'Automated rent due reminders with invoice details',
      'Generate download-friendly lease agreement checklists'
    ]
  },
  {
    id: 'subscriptions',
    name: 'Subscription Tracker',
    desc: 'Track Netflix, Spotify, gym, and SaaS renewals, with renewal alerts and expense sums.',
    href: '#subscriptions',
    icon: '💳',
    color: '#c084fc',
    requiresLogin: true,
    isUpcoming: true,
    defaultOrder: 11,
    features: [
      'List Netflix, Spotify, gym, domain names, and recurring tools',
      'Sum monthly and annual subscription expenses in a simple graph',
      'Color-coded dashboard showing renewals in the next 7 days',
      'Auto-reminders before cards get charged'
    ]
  },
  {
    id: 'habits',
    name: 'Habit Tracker',
    desc: 'Build positive habits, track daily streaks, and view monthly consistency grids.',
    href: '#habits',
    icon: '⚡',
    color: '#06b6d4',
    requiresLogin: true,
    isUpcoming: true,
    defaultOrder: 12,
    features: [
      'Create customized daily, weekly, or flexible habits',
      'Toggle completion statuses directly from the home dashboard',
      'Analyze habit consistency via a GitHub-style activity contribution grid',
      'Track current streak vs. longest historic streak statistics'
    ]
  }
];

let sortedTools = [...TOOLS];

if (user) {
  loggedIn = true;
  userName = user.name || user.email.split('@')[0];
  try {
    const db = getDB(Astro);
    const usageList = await getToolUsage(db, user.userId) as Array<{tool_id: string, use_count: number}>;
    const usageMap = new Map<string, number>();
    usageList.forEach(item => {
      usageMap.set(item.tool_id, item.use_count);
    });

    sortedTools.sort((a, b) => {
      const aCount = usageMap.get(a.id) || 0;
      const bCount = usageMap.get(b.id) || 0;

      if (aCount > 0 && bCount > 0) {
        return bCount - aCount;
      } else if (aCount > 0) {
        return -1;
      } else if (bCount > 0) {
        return 1;
      } else {
        return a.defaultOrder - b.defaultOrder;
      }
    });
  } catch (err) {
    console.error('Error fetching tool usage from database:', err);
  }
}

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://mydashboard.co.in/#organization",
      "name": "My Dashboard",
      "url": "https://mydashboard.co.in/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://mydashboard.co.in/favicon.svg",
        "caption": "My Dashboard Logo"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://mydashboard.co.in/#website",
      "url": "https://mydashboard.co.in/",
      "name": "My Dashboard",
      "description": "Secure personal ledgers, quick checklists notes, expense logs, secure vaults, and smart calculation utilities in one dashboard.",
      "publisher": {
        "@id": "https://mydashboard.co.in/#organization"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://mydashboard.co.in/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  ]
};
---
<Layout 
  title="MYDASHBOARD.CO.IN - Manage Everything. One Dashboard."
  description="Manage your daily milk delivery ledgers (Doodh ka Hissab), monthly expenses, passwords, secure notes, and use online calculators in one place."
  schema={homeSchema}
>
  <main class="container animate-fade-in pb-12">
    <!-- Hero / Header -->
    <header class="dashboard-hero py-6 mb-6 text-center glass-card p-6">
      {loggedIn ? (
        <div>
          <span class="badge mb-2">Workspace Hub</span>
          <h1 class="h2 mb-1" style="font-weight: 800; letter-spacing: -0.02em;">Hello, <span class="text-accent">{userName}</span></h1>
          <p class="text-muted text-xs max-w-sm mx-auto">
            Quick launch your daily ledgers, tracker tools, notes, and password credentials.
          </p>
        </div>
      ) : (
        <div>
          <span class="badge mb-2">Utility Workspace</span>
          <h1 class="h2 mb-1" style="font-weight: 800; letter-spacing: -0.02em;">Welcome to <span class="text-accent">MYDASHBOARD.CO.IN</span></h1>
          <p class="text-muted text-xs max-w-sm mx-auto">
            manage everything. one dashboard.
          </p>
        </div>
      )}
    </header>

    <!-- Search Tool Panel -->
    <div class="glass-card mb-6 p-3">
      <div class="flex gap-2">
        <input type="text" id="toolSearch" class="form-control" placeholder="🔍 Search for available tools (e.g. milk, notes, age, calculator...)" autofocus>
      </div>
    </div>

    <!-- Grid Header -->
    <div class="flex-between mb-4">
      <div>
        <h2 class="h3 m-0" style="font-size: 1.25rem;">🛠️ Workspace Tools &amp; Utilities</h2>
        <p class="text-muted text-xs">Listed in order of your usage frequency.</p>
      </div>
      {loggedIn && (
        <span class="text-xs text-muted" style="background: rgba(255,255,255,0.05); padding: 0.2rem 0.6rem; border-radius: 4px; border: 1px solid var(--border-color);">
          🔒 Connected
        </span>
      )}
    </div>

    <!-- Tools Grid -->
    <div class={`tools-grid-container ${loggedIn ? 'is-logged-in' : ''}`}>
      <div class="tools-grid" id="tools-grid">
        {sortedTools.map(tool => {
          const glowColor = tool.color + '25'; // Hex alpha (approx 15% opacity)
          return (
            <div 
              class={`glass-card tool-card ${tool.isUpcoming ? 'upcoming' : ''}`}
              data-tool-id={tool.id}
              data-default-order={tool.defaultOrder}
              data-upcoming={tool.isUpcoming ? 'true' : 'false'}
              data-features={tool.features ? JSON.stringify(tool.features) : ''}
              data-requires-login={tool.requiresLogin ? 'true' : 'false'}
              style={`--tool-color: ${tool.color}; --tool-color-glow: ${glowColor};`}
            >
              <div class="tool-icon" style={`color: ${tool.color};`}>
                {tool.icon}
              </div>
              <div class="tool-content">
                <h3 class="h4 mb-1 tool-title flex-between" style="font-size: 1.1rem;">
                  <span>{tool.name}</span>
                  <span class="tool-status flex gap-1">
                    {tool.isUpcoming ? (
                      <span class="badge-sm badge-coming-soon">Upcoming</span>
                    ) : tool.requiresLogin ? (
                      <span class="badge-sm badge-locked" title="Requires login">🔒 Lock</span>
                    ) : (
                      <span class="badge-sm badge-free">Utility</span>
                    )}
                  </span>
                </h3>
                <p class="text-xs text-muted tool-desc leading-relaxed">
                  {tool.desc}
                </p>
                <div class="tool-footer mt-4 text-end">
                  {tool.isUpcoming ? (
                    <button class="btn btn-sm btn-secondary btn-preview-tool" style="width: 100%; justify-content: center;">
                      Preview Features 🚀
                    </button>
                  ) : (
                    <a href={tool.href} class="btn btn-sm btn-primary btn-launch-tool" style="width: 100%; justify-content: center; background: var(--tool-color); border-color: var(--tool-color);">
                      Launch Tool →
                    </a>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    <!-- Search Engine Optimization (SEO) Content Panel -->
    {!loggedIn && (
      <article class="glass-card p-6 mt-8" style="margin-top: 2rem;">
        <header class="mb-4">
          <h2 class="h3 text-accent mb-2" style="font-weight: 800; font-size: 1.4rem;">MYDASHBOARD.CO.IN — Manage Everything. One Dashboard.</h2>
          <p class="text-xs text-muted leading-relaxed">
            Welcome to the ultimate personal utility workspace and daily bookkeeping portal. Built mobile-first for high performance, security, and convenience, <strong>MYDASHBOARD.CO.IN</strong> consolidates your essential tracking logs, secure credentials vaults, quick notes, and utility calculations into a single, lightning-fast workspace.
          </p>
        </header>

        <div class="row gap-4" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); display: grid;">
          <div>
            <h3 class="h6 fw-bold mb-2">🥛 Daily Milk Ledger (Doodh ka Hissab)</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Keep an accurate digital register of your daily milk deliveries. Record morning/evening quantities, configure custom rates per supplier, automatically carry forward balances, and manage monthly payouts. Say goodbye to manual calendar logging and complex calculations.
            </p>
          </div>

          <div>
            <h3 class="h6 fw-bold mb-2">💸 Expense Manager &amp; Budget Tracker</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Track your daily expenses and monitor monthly spending habits. Categorize budgets, see real-time breakdowns of where your money goes, and ensure you stay within your limits. Our secure structure provides private expense logging on the Cloudflare D1 database.
            </p>
          </div>

          <div>
            <h3 class="h6 fw-bold mb-2">📝 Quick Sticky Notes &amp; Notepad</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Capture ideas, compose draft reminders, and compile daily to-do checklists on the fly. Organize your digital sticky notes with customizable colors and searchable hashtags. Reachable, fast, and structured for one-handed entry on any mobile phone.
            </p>
          </div>

          <div>
            <h3 class="h6 fw-bold mb-2">🔑 Password Manager &amp; Secure Vault</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Protect your online presence with a built-in credentials manager. Securely generate complex, random passwords, store website logins, and filter credentials by categories. Safe and encrypted with secure edge routing protocols.
            </p>
          </div>

          <div>
            <h3 class="h6 fw-bold mb-2">📊 Smart Calculations &amp; Age Calculator</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Access direct calculators without logging in. The Online Calculator handles immediate arithmetic on a sleek grid. The Age Calculator returns your exact age in years, months, and days, details your zodiac sign, and tracks your next birthday countdown.
            </p>
          </div>

          <div>
            <h3 class="h6 fw-bold mb-2">🚀 Upcoming Trackers &amp; Voter Roadmap</h3>
            <p class="text-xs text-muted leading-relaxed" style="margin: 0;">
              Shape the future of our multi-utility dashboard. Vote to expedite upcoming features, including the <strong>Gas Cylinder Delivery Tracker</strong>, regional <strong>Newspaper Ledger</strong>, student <strong>Tuition Fee Tracker</strong>, and monthly <strong>Rent Ledger</strong>.
            </p>
          </div>
        </div>
      </article>
    )}
  </main>

  <!-- Dynamic Upcoming Tool Modal -->
  <div id="upcomingModal" class="modal-overlay" style="display:none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title" id="upcomingTitle">🚀 Coming Soon</h3>
        <button class="modal-close" id="closeUpcomingBtn">&times;</button>
      </div>
      <div class="text-center p-2">
        <div id="upcomingIcon" style="font-size: 3.5rem; margin-bottom: 1rem;">🔥</div>
        <p id="upcomingDesc" class="text-muted text-sm mb-4">Details about the upcoming tracker...</p>
        
        <div class="highlight-box mb-4 text-start">
          <h4 class="h6 mb-2 fw-bold text-xs uppercase" style="letter-spacing:0.04em; color: var(--accent-primary);">💡 Planned Features:</h4>
          <ul id="upcomingFeatures" class="text-xs text-secondary space-y-2" style="padding-left: 1.2rem; list-style-type: disc;">
            <li>Feature details...</li>
          </ul>
        </div>

        <div class="flex gap-2 justify-center">
          <button class="btn btn-secondary btn-sm" id="closeUpcomingBtn2">Close</button>
          <button class="btn btn-primary btn-sm" id="btnVoteTool">👍 Vote for this Tool</button>
        </div>
        <div id="voteAlert" class="alert alert-success mt-3" style="display:none;">
          🎉 Your vote has been recorded! We are expediting the development of this tool.
        </div>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  /* Sponsored Ad Banner */
  .ad-banner {
    border: 1px dashed rgba(13, 148, 136, 0.25);
    background: rgba(13, 148, 136, 0.02);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
    margin-top: 2rem;
  }
  [data-theme="light"] .ad-banner {
    border-color: rgba(13, 148, 136, 0.4);
    background: rgba(13, 148, 136, 0.04);
  }
  .ad-tag {
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    font-size: 0.55rem;
    font-weight: 800;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    background: var(--border-color);
    padding: 0.15rem 0.5rem;
    border-radius: 0 0 4px 4px;
    white-space: nowrap;
  }
  .ad-box {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.55rem 0;
  }
  .ad-icon {
    font-size: 1.5rem;
  }

  /* Tools Grid specific styles */
  .tools-grid-container {
    width: 100%;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .tools-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s, box-shadow 0.3s;
    border-color: var(--border-color);
  }

  /* Accent line on top of each card */
  .tool-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--tool-color);
    opacity: 0.8;
  }

  .tool-card:hover {
    transform: translateY(-6px);
    border-color: var(--tool-color);
    box-shadow: 0 12px 30px var(--tool-color-glow);
  }

  .tool-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    width: 50px;
    height: 50px;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.03);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-subtle);
  }

  [data-theme="light"] .tool-icon {
    background: rgba(0, 0, 0, 0.02);
  }

  .tool-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    justify-content: space-between;
  }

  .tool-title {
    font-weight: 700;
  }

  .tool-desc {
    flex-grow: 1;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .badge-sm {
    font-size: 0.65rem;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .badge-coming-soon {
    background: rgba(234, 88, 12, 0.15);
    color: #ea580c;
    border: 1px solid rgba(234, 88, 12, 0.2);
  }

  .badge-locked {
    background: rgba(240, 160, 64, 0.15);
    color: var(--accent-warning);
    border: 1px solid rgba(240, 160, 64, 0.2);
  }

  .badge-free {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .btn-launch-tool {
    color: white !important;
  }
  .btn-launch-tool:hover {
    filter: brightness(1.1);
    box-shadow: 0 4px 12px var(--tool-color-glow);
  }

  /* Logged-in Mobile App Drawer Styles */
  @media (max-width: 639px) {
    .is-logged-in .tools-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .is-logged-in .tool-card {
      padding: 0.75rem 0.5rem;
      align-items: center;
      text-align: center;
      border-radius: var(--radius-md);
      cursor: pointer;
      min-height: 110px;
      justify-content: center;
    }

    /* Remove the top accent line since it's too busy in compact grid */
    .is-logged-in .tool-card::before {
      display: none;
    }

    .is-logged-in .tool-icon {
      font-size: 1.8rem;
      margin-bottom: 0.5rem;
      width: 44px;
      height: 44px;
      border-radius: var(--radius-md);
    }

    .is-logged-in .tool-content {
      align-items: center;
      width: 100%;
    }

    .is-logged-in .tool-title {
      font-size: 0.75rem !important;
      font-weight: 600;
      margin-bottom: 0 !important;
      display: flex;
      justify-content: center;
      width: 100%;
    }

    .is-logged-in .tool-title span:first-child {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 100%;
    }

    /* Hide descriptions, footers, badges for logged-in mobile app drawer */
    .is-logged-in .tool-status,
    .is-logged-in .tool-desc,
    .is-logged-in .tool-footer {
      display: none !important;
    }

    /* Differentiate upcoming tools in drawer */
    .is-logged-in .tool-card.upcoming {
      opacity: 0.65;
      border-style: dashed;
    }

    /* Interactive press feedback */
    .is-logged-in .tool-card:active {
      transform: scale(0.95);
      background: var(--bg-surface-hover);
      box-shadow: 0 4px 15px var(--tool-color-glow);
    }
  }
</style>



<script>
  // ─── LocalStorage Usage Sorting for Anonymous Users ───
  (function() {
    const isLoggedIn = document.documentElement.getAttribute('data-logged-in') === 'true';
    if (isLoggedIn) return;

    try {
      const localCounts = JSON.parse(localStorage.getItem('tool_usage_local') || '{}');
      const grid = document.getElementById('tools-grid');
      if (!grid) return;

      const cards = Array.from(grid.querySelectorAll('.tool-card')) as HTMLElement[];
      cards.sort((a, b) => {
        const aId = a.dataset.toolId || '';
        const bId = b.dataset.toolId || '';
        const aCount = localCounts[aId] || 0;
        const bCount = localCounts[bId] || 0;
        const aOrder = parseInt(a.dataset.defaultOrder || '99');
        const bOrder = parseInt(b.dataset.defaultOrder || '99');

        if (aCount > 0 && bCount > 0) {
          return bCount - aCount;
        } else if (aCount > 0) {
          return -1;
        } else if (bCount > 0) {
          return 1;
        } else {
          return aOrder - bOrder;
        }
      });

      // Re-append cards to grid in sorted order
      cards.forEach(card => grid.appendChild(card));
    } catch (e) {
      console.error('Error executing client-side sorting:', e);
    }
  })();

  // ─── Real-Time Search Filtering for Tools ───
  const toolSearch = document.getElementById('toolSearch') as HTMLInputElement;
  toolSearch?.addEventListener('input', () => {
    const q = toolSearch.value.toLowerCase().trim();
    document.querySelectorAll('.tool-card').forEach(card => {
      const c = card as HTMLElement;
      const title = c.querySelector('.tool-title')?.textContent?.toLowerCase() || '';
      const desc = c.querySelector('.tool-desc')?.textContent?.toLowerCase() || '';
      if (title.includes(q) || desc.includes(q)) {
        c.style.display = 'flex';
      } else {
        c.style.display = 'none';
      }
    });
  });

  // ─── Upcoming Tools Modal Interactivity ───
  const upcomingModal = document.getElementById('upcomingModal') as HTMLDivElement;
  const upcomingTitle = document.getElementById('upcomingTitle') as HTMLHeadingElement;
  const upcomingIcon = document.getElementById('upcomingIcon') as HTMLDivElement;
  const upcomingDesc = document.getElementById('upcomingDesc') as HTMLParagraphElement;
  const upcomingFeatures = document.getElementById('upcomingFeatures') as HTMLUListElement;
  const voteAlert = document.getElementById('voteAlert') as HTMLDivElement;
  const btnVoteTool = document.getElementById('btnVoteTool') as HTMLButtonElement;
  
  let currentActiveToolId = '';

  function openUpcomingModal(card: HTMLElement) {
    const toolId = card.dataset.toolId || '';
    const toolName = card.querySelector('.tool-title span')?.textContent || '';
    const toolIcon = card.querySelector('.tool-icon')?.textContent || '';
    const toolDesc = card.querySelector('.tool-desc')?.textContent || '';
    const featuresStr = card.dataset.features || '[]';
    
    currentActiveToolId = toolId;
    
    if (upcomingTitle) upcomingTitle.textContent = `🚀 Upcoming: ${toolName}`;
    if (upcomingIcon) upcomingIcon.textContent = toolIcon;
    if (upcomingDesc) upcomingDesc.textContent = toolDesc;
    
    if (upcomingFeatures) {
      try {
        const features = JSON.parse(featuresStr);
        if (Array.isArray(features) && features.length > 0) {
          upcomingFeatures.innerHTML = features.map(f => `<li>${f}</li>`).join('');
        } else {
          upcomingFeatures.innerHTML = '<li>Details regarding this ledger tool are currently being finalized.</li>';
        }
      } catch {
        upcomingFeatures.innerHTML = '<li>Details regarding this ledger tool are currently being finalized.</li>';
      }
    }

    // Reset Vote State
    if (voteAlert) voteAlert.style.display = 'none';
    if (btnVoteTool) {
      btnVoteTool.disabled = false;
      btnVoteTool.textContent = '👍 Vote for this Tool';
    }

    if (upcomingModal) upcomingModal.style.display = 'flex';
  }

  // Handle clicking on the tool card or its buttons
  document.getElementById('tools-grid')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    
    // Check if it's the preview button
    const previewBtn = target.closest('.btn-preview-tool');
    if (previewBtn) {
      const card = previewBtn.closest('.tool-card') as HTMLElement;
      if (card) {
        openUpcomingModal(card);
      }
      return;
    }

    // Check if it's the launch button
    const launchBtn = target.closest('.btn-launch-tool');
    if (launchBtn) {
      // Allow default link behavior
      return;
    }

    // Check if clicked on the card itself
    const card = target.closest('.tool-card') as HTMLElement;
    if (card) {
      const isUpcoming = card.dataset.upcoming === 'true';
      if (isUpcoming) {
        openUpcomingModal(card);
      } else {
        const launchLink = card.querySelector('.btn-launch-tool') as HTMLAnchorElement;
        if (launchLink) {
          window.location.href = launchLink.href;
        }
      }
    }
  });

  // Close modals
  const closeModal = () => {
    if (upcomingModal) upcomingModal.style.display = 'none';
  };
  document.getElementById('closeUpcomingBtn')?.addEventListener('click', closeModal);
  document.getElementById('closeUpcomingBtn2')?.addEventListener('click', closeModal);

  // Overlay Click closes modal
  upcomingModal?.addEventListener('click', (e) => {
    if (e.target === upcomingModal) {
      closeModal();
    }
  });

  // Vote Button Interactivity
  btnVoteTool?.addEventListener('click', () => {
    if (btnVoteTool) {
      btnVoteTool.disabled = true;
      btnVoteTool.textContent = 'Recording Vote...';
    }

    // Simulate saving the vote
    setTimeout(() => {
      // Record vote in local storage so it persists locally
      try {
        const votes = JSON.parse(localStorage.getItem('tool_votes') || '{}');
        votes[currentActiveToolId] = (votes[currentActiveToolId] || 0) + 1;
        localStorage.setItem('tool_votes', JSON.stringify(votes));
      } catch (e) {}

      if (btnVoteTool) btnVoteTool.textContent = 'Voted ✓';
      if (voteAlert) voteAlert.style.display = 'block';
    }, 800);
  });
</script>
