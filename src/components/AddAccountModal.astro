---
export interface Props {
  suppliers: any[];
  categories: any[];
  month: number;
  year: number;
}
const { suppliers, categories, month, year } = Astro.props;
const monthStart = `${year}-${String(month).padStart(2, '0')}-01`;
const monthEnd = `${year}-${String(month).padStart(2, '0')}-${new Date(year, month, 0).getDate()}`;
---
<div class="modal-overlay" id="addAccountModal" style="display:none;">
  <div class="modal-content">
    <div class="modal-header">
      <h5 class="modal-title" id="accModalTitle">New Milk Supplier</h5>
      <button class="modal-close" onclick="document.getElementById('addAccountModal').style.display='none'">&times;</button>
    </div>
    <div class="modal-body">
      <form id="accForm">
        <input type="hidden" name="action" value="add_or_edit_account">
        <input type="hidden" name="account_id" id="accAccountId" value="0">
        <input type="hidden" name="month" value={month}>
        <input type="hidden" name="year" value={year}>
        <div class="mb-3">
          <label class="form-label">Supplier *</label>
          <select class="form-select mb-2" name="supplier_id" id="accSupplierId">
            <option value="0">+ Create New Supplier</option>
            {suppliers.map((s: any) => (
              <option value={s.id}>{s.name}</option>
            ))}
          </select>
          <div id="newSupplierGroup">
            <input type="text" class="form-control" name="milksupplier_name" id="accSupplierName" placeholder="Enter new supplier name...">
          </div>
        </div>
        <div class="row mb-3">
          <div class="col-6">
            <label class="form-label">Category *</label>
            <select class="form-select" name="category_id" id="accCategory" required>
              {categories.map((c: any) => (
                <option value={c.id}>{c.name}</option>
              ))}
            </select>
          </div>
          <div class="col-3">
            <label class="form-label">Rate (₹/L)</label>
            <input type="number" step="0.01" class="form-control" name="rate" id="accRate" required>
          </div>
          <div class="col-3">
            <label class="form-label">Active</label>
            <label class="toggle" style="margin-top:4px;">
              <input type="checkbox" name="active" id="accActive" checked value="1">
              <div class="toggle-track"></div>
            </label>
          </div>
        </div>
        <div class="row mb-3">
          <div class="col-6">
            <label class="form-label">Start Date</label>
            <input type="date" class="form-control" name="start_date" id="accStart" value={monthStart}>
          </div>
          <div class="col-6">
            <label class="form-label">End Date</label>
            <input type="date" class="form-control" name="end_date" id="accEnd" value={monthEnd}>
          </div>
        </div>
        <div class="highlight-box mb-3">
          <h6 class="fw-bold mb-2">⚡ Auto-Generate Entries?</h6>
          <div class="row">
            <div class="col-6">
              <label class="form-label" style="margin-bottom:2px;">Quantity (kg)</label>
              <input type="number" step="0.01" class="form-control" name="autogen_quantity" id="accAutoQty" placeholder="e.g. 2">
            </div>
            <div class="col-6">
              <label class="form-label" style="margin-bottom:2px;">Time (IST)</label>
              <input type="time" class="form-control" name="autogen_time" id="accAutoTime" value="07:30">
            </div>
          </div>
        </div>
        <div class="flex gap-2">
          <button type="submit" class="btn btn-primary" style="flex:1;">Save Subscription</button>
          <button type="button" class="btn btn-danger btn-sm" id="accDelBtn" style="display:none;" title="Delete Monthly Config">🗓️✕</button>
          <button type="button" class="btn btn-danger btn-sm" id="supDelBtn" style="display:none;" title="Delete Supplier Forever">🗑️</button>
        </div>
        <div id="accAlert" class="alert alert-danger" style="display:none;"></div>
      </form>
    </div>
  </div>
</div>
<script>
  document.getElementById('accSupplierId')?.addEventListener('change', function(this: HTMLSelectElement) {
    const group = document.getElementById('newSupplierGroup')!;
    group.style.display = this.value === '0' ? 'block' : 'none';
  });
</script>