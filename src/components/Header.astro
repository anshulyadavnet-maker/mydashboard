---
export interface Props {
  month: number;
  year: number;
  monthName: string;
}
const { month, year, monthName } = Astro.props;
---
<div class="flex-between flex-wrap gap-3 mb-4">
  <div>
    <h2 style="font-size:1.5rem;font-weight:700;margin:0;display:flex;align-items:center;gap:0.5rem;">
      🥛 Milk Management
    </h2>
    <p class="text-muted text-sm" style="margin:0;">
      {monthName} {year} &mdash; Track daily milk intake, auto-generations, and arrears.
    </p>
  </div>
  <div class="flex gap-2">
    <button class="btn btn-primary" data-open="addAccountModal">
      + Add Supplier
    </button>
  </div>
</div>