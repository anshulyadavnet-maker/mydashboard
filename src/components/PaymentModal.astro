<div class="modal-overlay" id="payModal" style="display:none;">
  <div class="modal-content modal-sm" style="text-align:center;">
    <div class="modal-body">
      <span style="font-size:2.5rem;">💵</span>
      <h6 class="fw-bold mb-3" id="payModalTitle">Add Payment</h6>
      <form id="payForm">
        <input type="hidden" name="action" value="add_payment">
        <input type="hidden" name="payment_id" id="payPaymentId" value="0">
        <input type="hidden" name="account_id" id="payAccId">
        <input type="number" step="0.01" name="amount"
               class="form-control text-center mb-2 fw-bold"
               style="font-size:1.2rem;"
               placeholder="Amount (₹)" required autofocus>
        <input type="date" name="payment_date" class="form-control mb-2" id="payDate">
        <input type="text" name="note" class="form-control mb-3" placeholder="Add a note (e.g. UPI Ref, Cash)...">
        <button type="submit" class="btn btn-success w-100">Save Payment</button>
      </form>
    </div>
  </div>
</div>
<script>
  const now = new Date();
  const today = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
  const payDateEl = document.getElementById('payDate') as HTMLInputElement;
  if (payDateEl) payDateEl.value = today;
</script>